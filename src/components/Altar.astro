---
import { Icon } from "astro-icon/components";
import { Image } from "astro:assets";
import altarBig from "../assets/altar/altar48.webp";
import altarSmall from "../assets/altar/altar.webp";
---

<div id="altar">
  <Image
    src={altarBig}
    alt="Сиддхи и божества"
    format="avif"
    loading="lazy"
    decoding="async"
    class="hidden h-auto w-full rounded-sm lg:block"
  />
  <Image
    src={altarSmall}
    alt="Сиддхи и божества"
    format="avif"
    loading="lazy"
    decoding="async"
    class="block h-auto w-full rounded-xs lg:hidden"
  />
  <div class="flex h-7 w-full gap-1">
    <button
      class="altar mt-0.5 ml-1 rounded-sm border border-red-600 bg-red-600/20 dark:border-red-400"
    >
      <Icon
        id="fixAltarIcon"
        name="mdi:arrow-expand-all"
        class="size-5 text-red-600"
      />
      <Icon
        id="closeAltarIcon"
        name="mdi:window-close"
        class="hiddenIcon size-5 text-red-600"
      />
    </button>
  </div>
</div>

<script>
  const buttons = document.querySelectorAll("button.altar");
  const altar = document.getElementById("altar");
  const sutra = document.getElementById("sutra");
  const fixAltarIcon = document.getElementById("fixAltarIcon");
  const closeAltarIcon = document.getElementById("closeAltarIcon");

  buttons.forEach((button) => {
    button.addEventListener("click", () => {
      altar?.classList.toggle("fixAltar");
      sutra?.classList.toggle("marginTop");
      fixAltarIcon?.classList.toggle("hidden");
      closeAltarIcon?.classList.toggle("showIcon");
    });
  });
</script>
