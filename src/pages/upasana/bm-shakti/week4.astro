    </div>
    <div id="sutra"></div>
    <Altar />
    <Start client:visible />
    <GaneshaMantra client:visible />
    <GaneshaArati client:visible />
    <ShivaMantra client:visible />
    <PanchabrahmaMantry client:visible />
