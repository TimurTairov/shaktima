    <Disclaimer client:visible />

    <div class="mt-10 flex w-full justify-center text-lg lg:mt-20">
      <a href="/upasana/bm-vishnu/">
        <Icon
          name="mdi:arrow-left-top"
          class="size-5 text-indigo-500 md:size-6 lg:size-8 dark:text-amber-400"
        />
      </a>
    </div>
  </div>
</Layout>
