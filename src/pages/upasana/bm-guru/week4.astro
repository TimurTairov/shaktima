---
import Layout from "../../../layouts/Layout.astro";
import Altar from "../../../components/Altar.astro";
import Start from "../../../components/BhadjanMandala/Start";
import MahaAratiFull from "../../../components/BhadjanMandala/MahaAratiFull";
import GuruPadukaStotra from "../../../components/BhadjanMandala/GuruPadukaStotra";
import GuruYoga from "../../../components/BhadjanMandala/GuruYoga";
import Prarthana from "../../../components/BhadjanMandala/Prarthana";
import BhadjanyGuru from "../../../components/BhadjanMandala/BhadjanyGuru";
import LekciyaGuru from "../../../components/BhadjanMandala/LekciyaGuru";
import Meditation4BSB from "../../../components/BhadjanMandala/Meditation4BSB";
import Finish from "../../../components/BhadjanMandala/Finish";
import Disclaimer from "../../../components/BhadjanMandala/Disclaimer";
import PosvyasheneiZaslug from "../../../components/BhadjanMandala/PosvyasheneiZaslug";
import ShriGuruStotra from "../../../components/BhadjanMandala/ShriGuruStotra";
import ShriGuruGita from "../../../components/BhadjanMandala/ShriGuruGita";
import GuruDjayaKara from "../../../components/BhadjanMandala/GuruDjayaKara";
import Rakovina from "../../../components/BhadjanMandala/Rakovina";
import BhumiMangalam from "../../../components/BhadjanMandala/BhumiMangalam";
import ShantiMantras from "../../../components/BhadjanMandala/ShantiMantras";
import { Icon } from "astro-icon/components";
---

<Layout title="Пуджа Гуру. Неделя 4.">
  <div class="main-container">
    <div class="flex items-center justify-center gap-1">
      <h1 class="mainTitle">Пуджа Гуру. Неделя 4</h1>
      <a href="/upasana/bm-guru/" class="">
        <Icon
          name="mdi:arrow-left-top"
          class="size-5 text-indigo-500 md:size-6 lg:size-8 dark:text-amber-400"
        />
      </a>
    </div>
    <div id="sutra"></div>
    <Altar />
    <Start client:visible />
    <GuruPadukaStotra client:visible />
    <MahaAratiFull client:visible />
    <LekciyaGuru client:visible />
    <Rakovina client:visible />
    <Prarthana client:visible />
    <ShriGuruStotra client:visible />
    <BhadjanyGuru client:visible />
    <ShriGuruGita client:visible />
    <Rakovina client:visible />
    <GuruDjayaKara client:visible />
    <BhumiMangalam client:visible />
    <ShantiMantras client:visible />
    <GuruYoga client:visible />
    <Meditation4BSB client:visible />
    <PosvyasheneiZaslug client:visible />
    <Finish client:visible />
    <Disclaimer client:visible />

    <div class="mt-10 flex w-full justify-center text-lg lg:mt-20">
      <a href="/upasana/bm-guru/">
        <Icon
          name="mdi:arrow-left-top"
          class="size-5 text-indigo-500 md:size-6 lg:size-8 dark:text-amber-400"
        />
      </a>
    </div>
  </div>
</Layout>
