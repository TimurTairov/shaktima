---

<Layout title="Пуджа Даттатрее. Неделя 4.">
  <div class="main-container">
    <div class="flex items-center justify-center gap-1">
      <h1 class="mainTitle">Пуджа Даттатрее. Неделя 4</h1>
      <a href="/upasana/bm-datta/" class="">
        <Icon
          name="mdi:arrow-left-top"
          class="size-5 text-indigo-500 md:size-6 lg:size-8 dark:text-amber-400"
        />
      </a>
    </div>
    <div id="sutra"></div>
    <Altar />
    <Start client:visible />
    <GaneshaMantra client:visible />
    <GaneshaArati client:visible />
    <PanchabrahmaMantry client:visible />
    <ShriRudrashtakam client:visible />
    <ShadaksharaMantra client:visible />
    <BhadjanShive client:visible />
    <Rakovina client:visible />
    <ShivaArati client:visible />
    <Rakovina client:visible />
    <LaksmiArati client:visible />
    <Rakovina client:visible />
    <DattaArati client:visible />
    <LekciyaGuru client:visible />
    <Rakovina client:visible />
    <Prarthana client:visible />
    <ShantiStotra client:visible />
    <BhadjanyDattatree client:visible />
    <DattaDjayaKara client:visible />
    <Rakovina client:visible />
    <GuruYogasOM client:visible />
    <BhumiMangalam client:visible />
    <Meditation4BSB client:visible />
