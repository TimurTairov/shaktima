---
import Layout from "../../layouts/Layout.astro";
import { Image } from "astro:assets";
import guru from "../../assets/img/Lords/guru.webp";
import { Icon } from "astro-icon/components";
---

<Layout title="Пуджа Гуру">
  <section class="main-container">
    <div class="flex items-center justify-center gap-1">
      <h1 class="mainTitle">Четверг. Пуджа Гуру</h1>
      <a href="/upasana/" class="">
        <Icon
          name="mdi:arrow-left-top"
          class="size-5 text-indigo-500 md:size-6 lg:size-8 dark:text-amber-400"
        />
      </a>
    </div>
    <div class="flex w-full justify-center">
      <ul
        class="mt-10 flex flex-col justify-center gap-5 rounded-xl border-2 border-indigo-500 px-7 py-10 lg:justify-start xl:gap-10 dark:border-amber-400"
      >
        <li class="flex w-full items-center gap-3 md:w-80">
          <a
            href="/upasana/bm-guru/week1"
            class="w-full text-center text-xs text-indigo-500 md:text-sm lg:text-base xl:text-lg dark:text-amber-400"
          >
            Пуджа Гуру. 1-ая неделя.
          </a>
        </li>
        <li class="flex w-full items-center gap-3 md:w-80">
          <a
            href="/upasana/bm-guru/week2"
            class="w-full text-center text-xs text-indigo-500 md:text-sm lg:text-base xl:text-lg dark:text-amber-400"
          >
            Пуджа Гуру. 2-ая неделя.
          </a>
        </li>
        <li class="flex w-full items-center gap-3 md:w-80">
          <a
            href="/upasana/bm-guru/week3"
            class="w-full text-center text-xs text-indigo-500 md:text-sm lg:text-base xl:text-lg dark:text-amber-400"
          >
            Пуджа Гуру. 3-ая неделя.
          </a>
        </li>
        <li class="flex w-full items-center gap-3 md:w-80">
          <a
            href="/upasana/bm-guru/week4"
            class="w-full text-center text-xs text-indigo-500 md:text-sm lg:text-base xl:text-lg dark:text-amber-400"
          >
            Пуджа гуру. 4-ая неделя.
          </a>
        </li>
      </ul>
    </div>
    <div class="mt-10 flex w-full justify-center">
      <Image src={guru} alt="guru" class="" />
    </div>
  </section>
</Layout>
